#!/usr/bin/env bash
# ============================================================================
# opsx-status — status CLI for openspec-orbit projects
#
# Walks an openspec/ tree (plus .orbit-runs/ when present) and surfaces what's
# active, what phase each change is in, what needs attention, and where the
# developer is in the workflow. Read-only.
#
# Specs: openspec/changes/bootstrap-orbit-status-cli/specs/
# Author: openspec-orbit
# License: MIT
# ============================================================================

set -euo pipefail

VERSION="0.1.0-chunk5"

# ============================================================================
# Defaults
# ============================================================================

DETAIL=false
JSON=false
CHANGE=""
LIMIT=5

# ============================================================================
# Help text
# ============================================================================

usage() {
  cat <<'EOF'
Usage: opsx-status [--detail] [--json] [--change <name>] [--limit N]

Status CLI for openspec-orbit projects. Walks an openspec/ tree and
surfaces what's active, what phase each change is in, what needs attention,
and where the developer is in the workflow. Read-only.

Flags:
  --detail              Expanded per-change view (full review history
                        breakdown, full attention text, source field in
                        recommendations, next_unchecked task description)
  --json                Emit machine-readable JSON to stdout (suppresses
                        human-formatted text). Top-level keys: project,
                        focus, active, exploring, recent, totals.
  --change <name>       Pin focus to a specific thread (overrides default
                        most-recently-touched ranking)
  --limit N             Cap recent[] length (default 5; N must be a
                        non-negative integer)
  --help, -h            Show this help
  --version             Show version

Exit codes:
  0   Success
  1   Operational error (openspec/ not found, --change names a missing
      thread, --limit negative or non-numeric)
  2   Dependency error (jq not on PATH)

See .claude/skills/openspec-status/SKILL.md for the full surface and JSON
schema documentation.
EOF
}

# ============================================================================
# Argument parsing
# ============================================================================

while [[ $# -gt 0 ]]; do
  case "$1" in
    --detail) DETAIL=true; shift ;;
    --json) JSON=true; shift ;;
    --change)
      [[ $# -lt 2 ]] && { echo "Error: --change requires a change name argument" >&2; exit 1; }
      CHANGE="$2"; shift 2 ;;
    --limit)
      [[ $# -lt 2 ]] && { echo "Error: --limit requires an integer argument" >&2; exit 1; }
      [[ "$2" =~ ^[0-9]+$ ]] || { echo "Error: --limit requires a non-negative integer, got: $2" >&2; exit 1; }
      LIMIT="$2"; shift 2 ;;
    --help|-h) usage; exit 0 ;;
    --version) echo "opsx-status $VERSION"; exit 0 ;;
    *) echo "Error: unknown argument: $1" >&2; echo "" >&2; usage >&2; exit 1 ;;
  esac
done

# ============================================================================
# Dependency check: jq
# ============================================================================

if ! command -v jq >/dev/null 2>&1; then
  cat <<'EOF' >&2
Error: jq is required but not found on PATH.

Install:
  macOS:        brew install jq
  Ubuntu/Debian: sudo apt-get install jq
  Other:         https://stedolan.github.io/jq/download/
EOF
  exit 2
fi

# ============================================================================
# Locate project root
# ============================================================================

find_project_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/openspec" ]]; then
      printf '%s\n' "$dir"; return 0
    fi
    dir="$(dirname "$dir")"
  done
  [[ -d "/openspec" ]] && { printf '/\n'; return 0; }
  return 1
}

if ! PROJECT_ROOT="$(find_project_root)"; then
  cat <<EOF >&2
Error: no openspec/ project found in cwd or any ancestor directory.

Run opsx-status from within an openspec project, or run
'openspec init' first to scaffold one.
EOF
  exit 1
fi

PROJECT_NAME="$(basename "$PROJECT_ROOT")"

# ============================================================================
# Cross-platform helpers (BSD stat vs GNU stat)
# ============================================================================

mtime_epoch() {
  local f="$1"
  [[ ! -e "$f" ]] && return 1
  if [[ "$(uname)" == "Darwin" ]]; then
    stat -f '%m' "$f" 2>/dev/null
  else
    stat -c '%Y' "$f" 2>/dev/null
  fi
}

mtime_iso() {
  local f="$1"
  local epoch
  epoch="$(mtime_epoch "$f")" || { echo "1970-01-01T00:00:00Z"; return 1; }
  if [[ "$(uname)" == "Darwin" ]]; then
    date -u -r "$epoch" '+%Y-%m-%dT%H:%M:%SZ'
  else
    date -u -d "@$epoch" '+%Y-%m-%dT%H:%M:%SZ'
  fi
}

# Extract the embedded ISO-8601 timestamp from an .orbit-runs filename and
# convert to POSIX epoch seconds. Pattern: <command>-<YYYY-MM-DDTHH-MM-SSZ>.{json,md}
# Returns 0 if no parseable timestamp. Used for ordering runs by the run's
# semantic time (not by filesystem mtime, which is unstable under clone/cp/touch
# — caught by external review iter-1).
filename_ts_epoch() {
  local f="$1"
  local fname
  fname=$(basename "$f")
  if [[ "$fname" =~ ([0-9]{4})-([0-9]{2})-([0-9]{2})T([0-9]{2})-([0-9]{2})-([0-9]{2})Z ]]; then
    local iso="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}T${BASH_REMATCH[4]}:${BASH_REMATCH[5]}:${BASH_REMATCH[6]}Z"
    if [[ "$(uname)" == "Darwin" ]]; then
      date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$iso" '+%s' 2>/dev/null || echo 0
    else
      date -u -d "$iso" '+%s' 2>/dev/null || echo 0
    fi
  else
    echo 0
  fi
}

# Format an ISO-8601 UTC timestamp as a relative time like "2h ago", "3d ago".
# Returns "?" if unparseable. Used by emit_human's primary line per the
# orbit-status-output spec requirement that the default view include
# last-touched relative time (caught by external review iter-1).
relative_time() {
  local iso="$1"
  [[ -z "$iso" || "$iso" == "null" || "$iso" == "1970-01-01T00:00:00Z" ]] && { echo "?"; return; }
  local epoch
  if [[ "$(uname)" == "Darwin" ]]; then
    epoch=$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$iso" '+%s' 2>/dev/null || echo 0)
  else
    epoch=$(date -u -d "$iso" '+%s' 2>/dev/null || echo 0)
  fi
  [[ "$epoch" == "0" ]] && { echo "?"; return; }
  local now_epoch delta
  now_epoch=$(date -u +%s)
  delta=$((now_epoch - epoch))
  if   (( delta < 60 ));      then echo "just now"
  elif (( delta < 3600 ));    then echo "$((delta/60))m ago"
  elif (( delta < 86400 ));   then echo "$((delta/3600))h ago"
  elif (( delta < 604800 ));  then echo "$((delta/86400))d ago"
  elif (( delta < 2592000 )); then echo "$((delta/604800))w ago"
  else echo "$((delta/2592000))mo ago"
  fi
}

# ============================================================================
# is_orbit_project detection
# ============================================================================

detect_orbit_project() {
  if [[ -d "$PROJECT_ROOT/.claude/skills/openspec-review" ]]; then
    printf 'true\n'; return
  fi
  if [[ -d "$PROJECT_ROOT/openspec/changes" ]]; then
    if find "$PROJECT_ROOT/openspec/changes" -type d -name ".orbit-runs" -print -quit 2>/dev/null | grep -q .; then
      printf 'true\n'; return
    fi
  fi
  printf 'false\n'
}

IS_ORBIT_PROJECT="$(detect_orbit_project)"

# ============================================================================
# Enumeration
# ============================================================================

enumerate_active_changes() {
  local d="$PROJECT_ROOT/openspec/changes"
  [[ ! -d "$d" ]] && return 0
  find "$d" -mindepth 1 -maxdepth 1 -type d ! -name archive 2>/dev/null | sort
}

# Per spec: change-directory precedence — if openspec/changes/<name>/ exists,
# ignore openspec/explore/<name>/ for that name.
enumerate_explorations() {
  local d="$PROJECT_ROOT/openspec/explore"
  [[ ! -d "$d" ]] && return 0
  local changes_dir="$PROJECT_ROOT/openspec/changes"
  while IFS= read -r explore_dir; do
    [[ -z "$explore_dir" ]] && continue
    local name
    name=$(basename "$explore_dir")
    [[ -d "$changes_dir/$name" ]] && continue   # dedupe — changes wins
    echo "$explore_dir"
  done < <(find "$d" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
}

enumerate_archived_changes() {
  local d="$PROJECT_ROOT/openspec/changes/archive"
  [[ ! -d "$d" ]] && return 0
  find "$d" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort -r
}

# ============================================================================
# Per-change collection
# ============================================================================

collect_artifacts_present() {
  local dir="$1"
  local present=()
  [[ -f "$dir/proposal.md" ]] && present+=("proposal")
  [[ -f "$dir/design.md"   ]] && present+=("design")
  [[ -f "$dir/tasks.md"    ]] && present+=("tasks")
  [[ -d "$dir/specs"       ]] && present+=("specs")
  [[ -f "$dir/explore.md"  ]] && present+=("explore")
  [[ -d "$dir/sketches"    ]] && present+=("sketches")
  if [[ ${#present[@]} -eq 0 ]]; then
    echo '[]'
  else
    printf '%s\n' "${present[@]}" | jq -R . | jq -sc .
  fi
}

compute_last_touched() {
  local dir="$1"
  local newest_epoch=0
  local f
  for f in "$dir/proposal.md" "$dir/design.md" "$dir/tasks.md" "$dir/explore.md"; do
    [[ -f "$f" ]] || continue
    local epoch
    epoch="$(mtime_epoch "$f")" || continue
    (( epoch > newest_epoch )) && newest_epoch=$epoch
  done
  local sub
  for sub in "$dir/specs" "$dir/.orbit-runs" "$dir/sketches"; do
    [[ -d "$sub" ]] || continue
    while IFS= read -r f; do
      [[ -f "$f" ]] || continue
      local epoch
      epoch="$(mtime_epoch "$f")" || continue
      (( epoch > newest_epoch )) && newest_epoch=$epoch
    done < <(find "$sub" -type f 2>/dev/null)
  done

  if (( newest_epoch == 0 )); then
    echo "1970-01-01T00:00:00Z"
  else
    if [[ "$(uname)" == "Darwin" ]]; then
      date -u -r "$newest_epoch" '+%Y-%m-%dT%H:%M:%SZ'
    else
      date -u -d "@$newest_epoch" '+%Y-%m-%dT%H:%M:%SZ'
    fi
  fi
}

count_tasks() {
  local tasks_file="$1"
  [[ ! -f "$tasks_file" ]] && { echo "null"; return; }
  local completed unchecked
  completed=$(grep -c '^- \[x\]' "$tasks_file" 2>/dev/null || true); completed=${completed:-0}
  unchecked=$(grep -c '^- \[ \]' "$tasks_file" 2>/dev/null || true); unchecked=${unchecked:-0}
  local total=$((completed + unchecked))
  jq -n --argjson t "$total" --argjson c "$completed" --argjson u "$unchecked" \
    '{total: $t, completed: $c, unchecked: $u}'
}

find_next_unchecked() {
  local tasks_file="$1"
  [[ ! -f "$tasks_file" ]] && { echo null; return; }
  local line
  line=$(grep -m1 -E '^- \[ \] [0-9]+\.[0-9]+[a-z]? ' "$tasks_file" 2>/dev/null || true)
  [[ -z "$line" ]] && { echo null; return; }
  local desc
  desc=$(echo "$line" | sed -E 's/^- \[ \] [0-9]+\.[0-9]+[a-z]? //')
  jq -n --arg d "$desc" '$d'
}

# ============================================================================
# .orbit-runs ingestion
# ============================================================================

list_orbit_runs() {
  local change_dir="$1"
  local runs_dir="$change_dir/.orbit-runs"
  [[ ! -d "$runs_dir" ]] && return 0
  # Sort by the ISO-8601 timestamp embedded in each filename, not by full
  # filename. Full-name sort orders alphabetically by command prefix
  # (review-* sorts after address-reviews-* regardless of timestamp), which
  # produced wrong "latest run" selections — caught by external system
  # review iter-1.
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    local fname; fname=$(basename "$f")
    if [[ "$fname" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}Z) ]]; then
      printf '%s\t%s\n' "${BASH_REMATCH[1]}" "$f"
    fi
  done < <(find "$runs_dir" -maxdepth 1 -type f -name '*.json' 2>/dev/null) \
    | sort | cut -f2-
}

latest_orbit_run() {
  list_orbit_runs "$1" | tail -1
}

# Extracts the leading command type from an .orbit-runs filename:
#   review-proposal-2026-...Z.json → "review-proposal"
#   address-reviews-2026-...Z.json → "address-reviews"
#   archive-2026-...Z.json         → "archive"
#   audit-drift-2026-...Z.json     → "audit-drift"
orbit_run_command_type() {
  local path="$1"
  local fname; fname=$(basename "$path"); fname="${fname%.json}"
  echo "$fname" | sed -E 's/-[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}Z$//'
}

compute_review_history_summary() {
  local change_dir="$1"
  local runs_dir="$change_dir/.orbit-runs"
  [[ ! -d "$runs_dir" ]] && { echo null; return; }

  local iter_count
  iter_count=$(find "$runs_dir" -maxdepth 1 -type f \
    \( -name 'review-*.json' -o -name 'address-reviews-*.json' \) \
    2>/dev/null | wc -l | tr -d ' ')

  local findings_resolved=0
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if ! jq -e . "$f" >/dev/null 2>&1; then
      echo "Warning: failed to parse JSON: $f (treating as absent)" >&2
      continue
    fi
    local n
    n=$(jq -r '.resolution_summary.resolved // 0' "$f" 2>/dev/null || echo 0)
    findings_resolved=$((findings_resolved + n))
  done < <(find "$runs_dir" -maxdepth 1 -type f -name 'address-reviews-*.json' 2>/dev/null)

  if (( iter_count == 0 && findings_resolved == 0 )); then
    echo null
  else
    jq -n --argjson i "$iter_count" --argjson f "$findings_resolved" \
      '{iterations_total: $i, findings_resolved: $f}'
  fi
}

# Detailed review_history with per-mode breakdown (used under --detail).
# Counts:
#   proposal_internal:        review-proposal-*.json
#   proposal_external:        external-proposal-*.md
#   system_internal:          review-system-*.json
#   system_external:          external-system-*.md
#   address_reviews_proposal: address-reviews-*.json whose source traces to proposal mode
#   address_reviews_system:   address-reviews-*.json whose source traces to system mode
compute_review_history_detail() {
  local change_dir="$1"
  local runs_dir="$change_dir/.orbit-runs"
  [[ ! -d "$runs_dir" ]] && { echo null; return; }

  local prop_int=0 prop_ext=0 sys_int=0 sys_ext=0
  local ar_prop=0 ar_sys=0
  local findings_resolved=0

  # Per-mode internal reviews (filename-based)
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    case "$(basename "$f")" in
      review-proposal-*) prop_int=$((prop_int + 1)) ;;
      review-system-*)   sys_int=$((sys_int + 1)) ;;
    esac
  done < <(find "$runs_dir" -maxdepth 1 -type f -name 'review-*.json' 2>/dev/null)

  # External review files (markdown)
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    case "$(basename "$f")" in
      external-proposal-*) prop_ext=$((prop_ext + 1)) ;;
      external-system-*)   sys_ext=$((sys_ext + 1)) ;;
    esac
  done < <(find "$runs_dir" -maxdepth 1 -type f -name 'external-*.md' 2>/dev/null)

  # Address-reviews per mode + findings_resolved
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if ! jq -e . "$f" >/dev/null 2>&1; then
      echo "Warning: failed to parse JSON: $f (treating as absent)" >&2
      continue
    fi
    local source_field
    source_field=$(jq -r '.source_path // .source // empty' "$f" 2>/dev/null || true)
    case "$source_field" in
      *external-proposal-*|*review-proposal-*) ar_prop=$((ar_prop + 1)) ;;
      *external-system-*|*review-system-*)     ar_sys=$((ar_sys + 1)) ;;
      *) ar_prop=$((ar_prop + 1)) ;;  # default: proposal (inline_markers from --mark is proposal-only)
    esac
    local n
    n=$(jq -r '.resolution_summary.resolved // 0' "$f" 2>/dev/null || echo 0)
    findings_resolved=$((findings_resolved + n))
  done < <(find "$runs_dir" -maxdepth 1 -type f -name 'address-reviews-*.json' 2>/dev/null)

  local iter_total=$((prop_int + prop_ext + sys_int + sys_ext + ar_prop + ar_sys))

  if (( iter_total == 0 )); then
    echo null
  else
    jq -n \
      --argjson it "$iter_total" \
      --argjson fr "$findings_resolved" \
      --argjson pi "$prop_int" --argjson pe "$prop_ext" \
      --argjson si "$sys_int" --argjson se "$sys_ext" \
      --argjson ap "$ar_prop" --argjson as "$ar_sys" \
      '{
        iterations_total: $it,
        findings_resolved: $fr,
        breakdown: {
          proposal_internal: $pi,
          proposal_external: $pe,
          system_internal: $si,
          system_external: $se,
          address_reviews_proposal: $ap,
          address_reviews_system: $as
        }
      }'
  fi
}

# ============================================================================
# archived_at (3-tier priority)
# ============================================================================

compute_archived_at() {
  local archived_dir="$1"

  # Tier 1: archive-*.json timestamp field
  local archive_json
  archive_json=$(find "$archived_dir/.orbit-runs" -maxdepth 1 -type f -name 'archive-*.json' 2>/dev/null | sort | tail -1 || true)
  if [[ -n "$archive_json" && -f "$archive_json" ]]; then
    if jq -e . "$archive_json" >/dev/null 2>&1; then
      local ts
      ts=$(jq -r '.timestamp // empty' "$archive_json" 2>/dev/null || true)
      [[ -n "$ts" ]] && { echo "$ts"; return; }
    else
      echo "Warning: failed to parse JSON: $archive_json (treating as absent)" >&2
    fi
  fi

  # Tier 2: dated dir prefix
  local dn; dn=$(basename "$archived_dir")
  if [[ "$dn" =~ ^([0-9]{4}-[0-9]{2}-[0-9]{2})- ]]; then
    echo "${BASH_REMATCH[1]}T00:00:00Z"; return
  fi

  # Tier 3: dir mtime
  mtime_iso "$archived_dir"
}

clean_archived_name() {
  local n="$1"
  if [[ "$n" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}-(.+)$ ]]; then
    echo "${BASH_REMATCH[1]}"
  else
    echo "$n"
  fi
}

# ============================================================================
# Phase inference (precedence-ordered)
# ============================================================================

# Args:
#   $1 = change dir
#   $2 = kind ("active" | "exploring" | "recent")
infer_phase() {
  local dir="$1"
  local kind="$2"

  # Rule 1: under openspec/changes/archive/ → archived
  if [[ "$kind" == "recent" ]]; then
    echo "archived"; return
  fi

  # For exploring kind: phase is exploring unless we find evidence otherwise
  # (we've already deduped against active changes in enumerate_explorations)
  if [[ "$kind" == "exploring" ]]; then
    echo "exploring"; return
  fi

  # kind == "active" — apply rules 2-4
  # Rule 2: most recent .orbit-runs JSON command type, provided JSON is newer
  # than tasks.md mtime (freshness condition per W2 resolution)
  local latest; latest=$(latest_orbit_run "$dir")
  if [[ -n "$latest" ]]; then
    local json_epoch tasks_epoch
    # Use the JSON's filename-embedded ISO-8601 timestamp, NOT the filesystem
    # mtime. Filesystem mtimes are unstable under clone/cp/touch/checkout —
    # an old run could be made to look fresh by touching the file. Filename
    # timestamps reflect the run's semantic time. Caught by external system
    # review iter-1.
    json_epoch=$(filename_ts_epoch "$latest")
    tasks_epoch=0
    [[ -f "$dir/tasks.md" ]] && tasks_epoch=$(mtime_epoch "$dir/tasks.md" 2>/dev/null || echo 0)

    # Strict > per spec ("newer than tasks.md mtime"). Equal timestamps fall
    # through to rule 3 so a fresh edit to tasks doesn't get stuck under a
    # stale-by-the-second review JSON.
    if (( json_epoch > tasks_epoch )); then
      local cmd; cmd=$(orbit_run_command_type "$latest")
      case "$cmd" in
        archive)                      echo "archived"; return ;;
        review-*|address-reviews-*)   echo "reviewing"; return ;;
        review|address-reviews)       echo "reviewing"; return ;;
      esac
    fi
  fi

  # Rule 3: tasks.md with any [x] AND any [ ] → applying
  if [[ -f "$dir/tasks.md" ]]; then
    local cmp unc
    cmp=$(grep -c '^- \[x\]' "$dir/tasks.md" 2>/dev/null || true); cmp=${cmp:-0}
    unc=$(grep -c '^- \[ \]' "$dir/tasks.md" 2>/dev/null || true); unc=${unc:-0}
    if (( cmp > 0 && unc > 0 )); then
      echo "applying"; return
    fi
  fi

  # Rule 4: proposal.md exists, no [x] in tasks (or tasks.md absent) → proposed
  if [[ -f "$dir/proposal.md" ]]; then
    local cmp=0
    [[ -f "$dir/tasks.md" ]] && cmp=$(grep -c '^- \[x\]' "$dir/tasks.md" 2>/dev/null || true)
    cmp=${cmp:-0}
    if (( cmp == 0 )); then
      echo "proposed"; return
    fi
  fi

  # Rule 5 only applies to exploring kind (handled above).
  # Rule 6 (verified) reserved for /opsx:verify run-summary JSONs (future).
  # Fallback: applying (covers all-checked tasks.md before a system review)
  echo "applying"
}

# ============================================================================
# Attention signal detection
# ============================================================================

# Returns a JSON array of attention entries for a change dir.
# Closed enum: unresolved_marker, stale_review, audit_divergence.
# task_blocked deferred to v2 (NOOP per spec).
collect_attention() {
  local change_dir="$1"
  local entries='[]'

  # 8.1 unresolved_marker: scan artifacts (markdown) for lines starting @review:
  while IFS= read -r grepline; do
    [[ -z "$grepline" ]] && continue
    # grepline format: <file>:<lineno>:<content>
    local file lineno text
    file=$(echo "$grepline" | cut -d: -f1)
    lineno=$(echo "$grepline" | cut -d: -f2)
    text=$(echo "$grepline" | cut -d: -f3-)
    text=$(echo "$text" | sed 's/^[[:space:]]*//')
    local rel="${file#$change_dir/}"
    local entry
    entry=$(jq -nc \
      --arg loc "$rel:$lineno" \
      --arg text "$text" \
      '{type: "unresolved_marker", location: $loc, text: $text}')
    entries=$(echo "$entries" | jq -c --argjson e "$entry" '. + [$e]')
  done < <(grep -rn '^@review:' "$change_dir" --include='*.md' 2>/dev/null || true)

  # 8.2 stale_review: artifact mtime > latest review-*.json mtime
  local latest_review
  latest_review=$(find "$change_dir/.orbit-runs" -maxdepth 1 -type f -name 'review-*.json' 2>/dev/null | sort | tail -1 || true)
  if [[ -n "$latest_review" ]]; then
    local rev_epoch
    rev_epoch=$(mtime_epoch "$latest_review" 2>/dev/null || echo 0)
    local f
    for f in "$change_dir/proposal.md" "$change_dir/design.md" "$change_dir/tasks.md" "$change_dir/explore.md"; do
      [[ -f "$f" ]] || continue
      local fe
      fe=$(mtime_epoch "$f" 2>/dev/null || echo 0)
      if (( fe > rev_epoch )); then
        local rel="${f#$change_dir/}"
        local since
        since=$(mtime_iso "$f")
        local entry
        entry=$(jq -nc \
          --arg loc "$rel" \
          --arg since "$since" \
          '{type: "stale_review", location: $loc, since: $since}')
        entries=$(echo "$entries" | jq -c --argjson e "$entry" '. + [$e]')
      fi
    done
    # Also walk specs/
    if [[ -d "$change_dir/specs" ]]; then
      while IFS= read -r f; do
        [[ -f "$f" ]] || continue
        local fe
        fe=$(mtime_epoch "$f" 2>/dev/null || echo 0)
        if (( fe > rev_epoch )); then
          local rel="${f#$change_dir/}"
          local since
          since=$(mtime_iso "$f")
          local entry
          entry=$(jq -nc \
            --arg loc "$rel" \
            --arg since "$since" \
            '{type: "stale_review", location: $loc, since: $since}')
          entries=$(echo "$entries" | jq -c --argjson e "$entry" '. + [$e]')
        fi
      done < <(find "$change_dir/specs" -type f -name '*.md' 2>/dev/null)
    fi
  fi

  # 8.3 audit_divergence: count of findings in latest audit-drift-*.json
  # (Suppressed on plain-openspec projects per the degradation spec.)
  if [[ "$IS_ORBIT_PROJECT" == "true" ]]; then
    local latest_audit
    latest_audit=$(find "$change_dir/.orbit-runs" -maxdepth 1 -type f -name 'audit-drift-*.json' 2>/dev/null | sort | tail -1 || true)
    if [[ -n "$latest_audit" ]]; then
      if jq -e . "$latest_audit" >/dev/null 2>&1; then
        local count
        count=$(jq -r '(.findings_summary.critical // 0) + (.findings_summary.warning // 0) + (.findings_summary.suggestion // 0)' "$latest_audit" 2>/dev/null || echo 0)
        if (( count > 0 )); then
          local rel=".orbit-runs/$(basename "$latest_audit")"
          local entry
          entry=$(jq -nc \
            --arg loc "$rel" \
            --argjson count "$count" \
            '{type: "audit_divergence", location: $loc, count: $count}')
          entries=$(echo "$entries" | jq -c --argjson e "$entry" '. + [$e]')
        fi
      else
        echo "Warning: failed to parse JSON: $latest_audit (treating as absent)" >&2
      fi
    fi
  fi

  # 8.4 task_blocked: deferred to v2 (NOOP — enum slot defined in spec, no emission)

  echo "$entries"
}

# ============================================================================
# Tier-1 best-effort parse of next_recommended string
# ============================================================================

# Returns a JSON object {command, args} or null when no parseable leading
# /opsx:<verb> token is found.
parse_next_recommended_string() {
  local s="$1"
  # Strip leading whitespace
  s="${s#"${s%%[![:space:]]*}"}"
  # Look for /opsx:<verb> at the start, optional <args> (single token to next whitespace/period/quote)
  if [[ "$s" =~ ^/opsx:([a-z-]+)([[:space:]]+([^[:space:]\".\']+))? ]]; then
    local verb="${BASH_REMATCH[1]}"
    local args="${BASH_REMATCH[3]:-}"
    jq -nc --arg c "/opsx:$verb" --arg a "$args" '{command: $c, args: $a}'
  else
    echo null
  fi
}

# ============================================================================
# Recommendation engine (3-tier hierarchy)
# ============================================================================

# Args:
#   $1 = change dir (empty for project-level / tier-3 fallback)
#   $2 = attention JSON array (for marker override check)
#   $3 = kind ("active" | "exploring" | "recent" | "" for tier-3)
compute_recommended_next() {
  local dir="$1"
  local attention="$2"
  local kind="$3"
  local cmd="" args="" reason="" source_label=""

  if [[ -z "$dir" ]]; then
    # Tier 3 — no active or exploring threads project-wide
    cmd="/opsx:explore"
    args="<name>"
    reason="No active workflow. Use /opsx:explore to start one."
    source_label="tier-3 (project-level fallback)"
  else
    local name
    name=$(basename "$dir")
    [[ "$kind" == "recent" ]] && name=$(clean_archived_name "$name")

    # Tier-1 marker override (fires before reading the JSON's recommendation)
    local marker_count
    marker_count=$(echo "$attention" | jq '[.[] | select(.type == "unresolved_marker")] | length')
    if (( marker_count > 0 )); then
      cmd="/opsx:address-reviews"
      args="$name"
      reason="$marker_count unresolved @review: markers in the change's artifacts; resolve before proceeding."
      source_label="tier-1 marker override"
    else
      # Tier 1: read next_recommended from latest .orbit-runs JSON
      local latest_json
      latest_json=$(latest_orbit_run "$dir")
      if [[ -n "$latest_json" ]]; then
        if jq -e . "$latest_json" >/dev/null 2>&1; then
          local nr
          nr=$(jq -r '.next_recommended // empty' "$latest_json" 2>/dev/null || true)
          if [[ -n "$nr" ]]; then
            reason="$nr"
            local parsed
            parsed=$(parse_next_recommended_string "$nr")
            if [[ "$parsed" != "null" ]]; then
              cmd=$(echo "$parsed" | jq -r '.command')
              args=$(echo "$parsed" | jq -r '.args')
            fi
            source_label="tier-1 (.orbit-runs/$(basename "$latest_json"))"
          fi
        else
          echo "Warning: failed to parse JSON: $latest_json (treating as absent)" >&2
        fi
      fi

      # Tier 2: synthesis ruleset (fires when no .orbit-runs/, or tier-1 produced nothing)
      if [[ -z "$reason" ]]; then
        # Rule 1: exploration only
        if [[ "$kind" == "exploring" ]]; then
          cmd="/opsx:propose"
          args="$name"
          reason="Exploration captured; promote to a formal change via /opsx:propose."
          source_label="tier-2 (rule 1: explore-only)"
        # Rule 2: proposal but no tasks.md
        elif [[ -f "$dir/proposal.md" && ! -f "$dir/tasks.md" ]]; then
          cmd="/opsx:propose"
          args="$name"
          reason="Proposal exists but tasks.md is missing; continue artifact generation."
          source_label="tier-2 (rule 2: artifacts incomplete)"
        elif [[ -f "$dir/tasks.md" ]]; then
          local cmp unc
          cmp=$(grep -c '^- \[x\]' "$dir/tasks.md" 2>/dev/null || true); cmp=${cmp:-0}
          unc=$(grep -c '^- \[ \]' "$dir/tasks.md" 2>/dev/null || true); unc=${unc:-0}
          local has_review=false
          [[ -d "$dir/.orbit-runs" ]] && find "$dir/.orbit-runs" -maxdepth 1 -type f -name 'review-*.json' 2>/dev/null | grep -q . && has_review=true

          # Rule 3: tasks all unchecked, no review JSON → /opsx:review
          if (( cmp == 0 )) && ! $has_review; then
            cmd="/opsx:review"
            args="$name"
            reason="All tasks unchecked; run a proposal-mode review before /opsx:apply."
            source_label="tier-2 (rule 3: pre-review)"
          # Rule 4: tasks with partial completion → /opsx:apply
          elif (( cmp > 0 && unc > 0 )); then
            cmd="/opsx:apply"
            args="$name"
            reason="Partial tasks; continue applying."
            source_label="tier-2 (rule 4: in-apply)"
          fi
        fi

        # Tier-2 fallback (shouldn't normally hit if rules are exhaustive)
        if [[ -z "$reason" ]]; then
          cmd="/opsx:review"
          args="$name"
          reason="No active orbit emissions; consider a proposal-mode review."
          source_label="tier-2 (fallback)"
        fi
      fi
    fi
  fi

  # Emit. Plain-openspec degradation: omit source even under --detail
  # (tier 1 unreachable on plain-openspec; source field assumes orbit-aware
  # consumers and adds noise without value on plain projects).
  if $DETAIL && [[ "$IS_ORBIT_PROJECT" == "true" ]]; then
    jq -nc \
      --arg c "$cmd" --arg a "$args" --arg r "$reason" --arg s "$source_label" \
      '{command: $c, args: $a, reason: $r, source: $s}'
  else
    jq -nc \
      --arg c "$cmd" --arg a "$args" --arg r "$reason" \
      '{command: $c, args: $a, reason: $r}'
  fi
}

# ============================================================================
# ChangeRecord builder
# ============================================================================

build_change_record() {
  local dir="$1"
  local kind="$2"
  local name
  if [[ "$kind" == "recent" ]]; then
    name=$(clean_archived_name "$(basename "$dir")")
  else
    name=$(basename "$dir")
  fi

  local artifacts last_touched review_history phase attention tasks
  artifacts=$(collect_artifacts_present "$dir")
  last_touched=$(compute_last_touched "$dir")
  if $DETAIL; then
    review_history=$(compute_review_history_detail "$dir")
  else
    review_history=$(compute_review_history_summary "$dir")
  fi
  phase=$(infer_phase "$dir" "$kind")

  # Attention: only for active + exploring (archived changes don't carry live attention)
  if [[ "$kind" == "recent" ]]; then
    attention='[]'
  else
    attention=$(collect_attention "$dir")
  fi

  tasks="null"
  if [[ -f "$dir/tasks.md" ]]; then
    tasks=$(count_tasks "$dir/tasks.md")
    if $DETAIL; then
      local nxt
      nxt=$(find_next_unchecked "$dir/tasks.md")
      tasks=$(echo "$tasks" | jq --argjson n "$nxt" '. + {next_unchecked: $n}')
    fi
  fi

  local base
  base=$(jq -nc \
    --arg name "$name" \
    --arg phase "$phase" \
    --argjson artifacts "$artifacts" \
    --argjson tasks "$tasks" \
    --argjson review_history "$review_history" \
    --argjson attention "$attention" \
    --arg last_touched "$last_touched" \
    '{
      name: $name,
      phase: $phase,
      artifacts_present: $artifacts,
      tasks: $tasks,
      review_history: $review_history,
      attention: $attention,
      last_touched: $last_touched
    }')

  # Plain-openspec degradation: omit review_history when not an orbit project.
  if [[ "$IS_ORBIT_PROJECT" == "false" ]]; then
    base=$(echo "$base" | jq -c 'del(.review_history)')
  fi

  if [[ "$kind" == "recent" ]]; then
    local archived_at
    archived_at=$(compute_archived_at "$dir")
    echo "$base" | jq -c --arg at "$archived_at" '. + {archived_at: $at}'
  else
    echo "$base"
  fi
}

# ============================================================================
# Array builders
# ============================================================================

build_active_array() {
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    build_change_record "$d" active
  done < <(enumerate_active_changes) | jq -sc .
}

build_exploring_array() {
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    build_change_record "$d" exploring
  done < <(enumerate_explorations) | jq -sc .
}

build_recent_array() {
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    build_change_record "$d" recent
  done < <(enumerate_archived_changes) \
    | jq -sc --argjson lim "$LIMIT" 'sort_by(.archived_at) | reverse | .[0:$lim]'
}

# ============================================================================
# Multi-change focus ranking
# ============================================================================

# Picks primary + builds secondary_threads + computes focus block.
# Args:
#   $1 = active array JSON
#   $2 = exploring array JSON
# Emits the full focus object (or tier-3 fallback) to stdout.
compute_focus() {
  local active_arr="$1"
  local exploring_arr="$2"
  local total
  total=$(jq -n --argjson a "$active_arr" --argjson e "$exploring_arr" '($a | length) + ($e | length)')

  # Tier 3: no active or exploring
  if (( total == 0 )); then
    local rec
    rec=$(compute_recommended_next "" "[]" "")
    jq -nc --argjson rec "$rec" \
      '{summary: "No active workflow.", recommended_next: $rec}'
    return
  fi

  # Combine + label kind on each entry
  local combined
  combined=$(jq -nc \
    --argjson a "$active_arr" \
    --argjson e "$exploring_arr" \
    '($a | map(. + {kind: "active"})) + ($e | map(. + {kind: "exploring"}))')

  # --change override
  local primary primary_kind ranking_basis
  if [[ -n "$CHANGE" ]]; then
    primary=$(echo "$combined" | jq -c --arg n "$CHANGE" '[.[] | select(.name == $n)] | .[0]')
    if [[ "$primary" == "null" ]]; then
      local active_names exploring_names
      active_names=$(echo "$active_arr" | jq -r '[.[].name] | join(", ")')
      exploring_names=$(echo "$exploring_arr" | jq -r '[.[].name] | join(", ")')
      echo "Error: --change argument '$CHANGE' doesn't name an active or exploring thread." >&2
      [[ -n "$active_names" && "$active_names" != "" ]] && echo "  Active threads: $active_names" >&2
      [[ -n "$exploring_names" && "$exploring_names" != "" ]] && echo "  Exploring threads: $exploring_names" >&2
      exit 1
    fi
    ranking_basis="user_specified"
  else
    # Default ranking: last_touched DESC, name ASC on ties.
    # Multi-key sort via composite: [-(numeric ts), name].
    primary=$(echo "$combined" | jq -c '
      sort_by([
        -(.last_touched | gsub("[-T:Z]"; "") | tonumber),
        .name
      ]) | .[0]')
    ranking_basis="most_recently_touched"
  fi

  primary_kind=$(echo "$primary" | jq -r '.kind')
  local primary_name
  primary_name=$(echo "$primary" | jq -r '.name')

  # Recommended next, based on primary's change dir
  # Reconstruct change dir from primary's kind + name
  local primary_dir
  if [[ "$primary_kind" == "active" ]]; then
    primary_dir="$PROJECT_ROOT/openspec/changes/$primary_name"
  else  # exploring
    primary_dir="$PROJECT_ROOT/openspec/explore/$primary_name"
  fi
  local primary_attention
  primary_attention=$(echo "$primary" | jq '.attention // []')
  local rec
  rec=$(compute_recommended_next "$primary_dir" "$primary_attention" "$primary_kind")

  # Build secondary_threads
  local secondary
  secondary=$(echo "$combined" | jq -c --arg pn "$primary_name" '
    sort_by([
      -(.last_touched | gsub("[-T:Z]"; "") | tonumber),
      .name
    ])
    | map(select(.name != $pn))
    | map({
        name: .name,
        kind: .kind,
        phase: .phase,
        summary: ([
          .phase,
          (if (.tasks // null) != null and ((.tasks.total // 0) > 0)
            then "\(.tasks.completed)/\(.tasks.total) tasks"
            else empty
          end),
          (if ((.attention // []) | length) > 0
            then "\((.attention | length)) attention"
            else empty
          end)
        ] | join(" · "))
      })')

  # Summary line for the primary. Phase-aware: gerund phases use the
  # "You are <phase> <name>" form; non-gerund phases use "<name> is <phase>".
  local summary
  if (( total == 1 )); then
    summary=$(echo "$primary" | jq -r '
      if .phase == "exploring" or .phase == "applying" or .phase == "reviewing"
        then "You are \(.phase) \(.name)."
        else "\(.name) is \(.phase)."
      end
    ')
  else
    local primary_phase
    primary_phase=$(echo "$primary" | jq -r '.phase')
    summary=$(printf '%d threads active. Primary: %s (%s).' "$total" "$primary_name" "$primary_phase")
  fi

  jq -nc \
    --arg summary "$summary" \
    --arg primary_change "$primary_name" \
    --arg primary_change_kind "$primary_kind" \
    --arg ranking_basis "$ranking_basis" \
    --argjson rec "$rec" \
    --argjson secondary "$secondary" \
    '{
      summary: $summary,
      primary_change: $primary_change,
      primary_change_kind: $primary_change_kind,
      ranking_basis: $ranking_basis,
      recommended_next: $rec,
      secondary_threads: $secondary
    }'
}

# ============================================================================
# Emit
# ============================================================================

emit_json() {
  local active_arr exploring_arr recent_arr archived_total focus

  active_arr=$(build_active_array)
  exploring_arr=$(build_exploring_array)
  recent_arr=$(build_recent_array)
  archived_total=$(enumerate_archived_changes | wc -l | tr -d ' ')
  focus=$(compute_focus "$active_arr" "$exploring_arr")

  jq -n \
    --arg path "$PROJECT_ROOT" \
    --arg name "$PROJECT_NAME" \
    --argjson is_orbit "$IS_ORBIT_PROJECT" \
    --argjson active "$active_arr" \
    --argjson exploring "$exploring_arr" \
    --argjson recent "$recent_arr" \
    --argjson archived_total "$archived_total" \
    --argjson focus "$focus" \
    '{
      project: {
        path: $path,
        name: $name,
        is_orbit_project: $is_orbit
      },
      focus: $focus,
      active: $active,
      exploring: $exploring,
      recent: $recent,
      totals: {
        active: ($active | length),
        exploring: ($exploring | length),
        archived: $archived_total
      }
    }'
}

emit_human() {
  local tag=""
  [[ "$IS_ORBIT_PROJECT" == "true" ]] && tag=" (orbit project)"
  printf '%s%s\n' "$PROJECT_ROOT" "$tag"
  echo ""

  # Compute the focus (drives both summary and primary recommendation)
  local active_arr exploring_arr recent_arr focus
  active_arr=$(build_active_array)
  exploring_arr=$(build_exploring_array)
  recent_arr=$(build_recent_array)
  focus=$(compute_focus "$active_arr" "$exploring_arr")

  local total
  total=$(jq -n --argjson a "$active_arr" --argjson e "$exploring_arr" '($a | length) + ($e | length)')

  if (( total == 0 )); then
    echo "No active workflow. Use /opsx:explore to start one."
    local archived_total
    archived_total=$(enumerate_archived_changes | wc -l | tr -d ' ')
    if (( archived_total > 0 )); then
      echo ""
      echo "Recently archived: $archived_total total (showing up to $LIMIT)"
      echo "$recent_arr" | jq -r '.[] | "  \(.name) · archived \(.archived_at | split("T")[0])"'
    fi
    return
  fi

  # Surface the focus summary + recommendation
  local summary primary_name primary_kind
  summary=$(echo "$focus" | jq -r '.summary')
  primary_name=$(echo "$focus" | jq -r '.primary_change')
  primary_kind=$(echo "$focus" | jq -r '.primary_change_kind')

  echo "$summary"

  # Primary thread one-liner
  local primary_record
  if [[ "$primary_kind" == "active" ]]; then
    primary_record=$(echo "$active_arr" | jq -c --arg n "$primary_name" '.[] | select(.name == $n)')
  else
    primary_record=$(echo "$exploring_arr" | jq -c --arg n "$primary_name" '.[] | select(.name == $n)')
  fi
  if [[ -n "$primary_record" && "$primary_record" != "null" ]]; then
    local pphase ptasks pattn ptouched_iso ptouched rel
    pphase=$(echo "$primary_record" | jq -r '.phase')
    ptasks=$(echo "$primary_record" | jq -r 'if (.tasks // null) != null and (.tasks.total // 0) > 0 then "\(.tasks.completed)/\(.tasks.total) tasks" else "" end')
    pattn=$(echo "$primary_record" | jq -r 'if ((.attention // []) | length) > 0 then "\(.attention | length) attention" else "" end')

    # Per orbit-status-output spec: primary line covers task progress,
    # attention counts, AND last-touched relative time (caught missing by
    # external system review iter-1).
    ptouched_iso=$(echo "$primary_record" | jq -r '.last_touched // empty')
    ptouched=""
    if [[ -n "$ptouched_iso" ]]; then
      rel=$(relative_time "$ptouched_iso")
      [[ "$rel" != "?" ]] && ptouched="touched $rel"
    fi

    # Compose ' · '-separated state segments
    local primary_line=""
    [[ -n "$ptasks" ]] && primary_line="$ptasks"
    if [[ -n "$pattn" ]]; then
      [[ -n "$primary_line" ]] && primary_line="$primary_line · $pattn" || primary_line="$pattn"
    fi
    if [[ -n "$ptouched" ]]; then
      [[ -n "$primary_line" ]] && primary_line="$primary_line · $ptouched" || primary_line="$ptouched"
    fi
    [[ -n "$primary_line" ]] && printf '  %s\n' "$primary_line"

    # --detail expansions: next_unchecked, attention details, review_history breakdown
    if $DETAIL; then
      local pnext
      pnext=$(echo "$primary_record" | jq -r '.tasks.next_unchecked // empty')
      if [[ -n "$pnext" && "$pnext" != "null" ]]; then
        printf '  next: %s\n' "$pnext"
      fi

      local attn_count
      attn_count=$(echo "$primary_record" | jq -r '(.attention // []) | length')
      if (( attn_count > 0 )); then
        echo ""
        echo "  attention:"
        echo "$primary_record" | jq -r '.attention[] |
          if .type == "unresolved_marker" then
            "    [\(.type)] \(.location) — \(.text)"
          elif .type == "stale_review" then
            "    [\(.type)] \(.location) (modified \(.since))"
          elif .type == "audit_divergence" then
            "    [\(.type)] \(.location) — \(.count) finding(s)"
          else
            "    [\(.type)] \(.location)"
          end'
      fi

      # Review history (only emitted on orbit projects; omitted on plain-openspec)
      local rh
      rh=$(echo "$primary_record" | jq '.review_history // null')
      if [[ "$rh" != "null" ]]; then
        echo ""
        local rh_iter rh_resolved
        rh_iter=$(echo "$rh" | jq -r '.iterations_total // 0')
        rh_resolved=$(echo "$rh" | jq -r '.findings_resolved // 0')
        printf '  review history: %s iteration(s) · %s finding(s) resolved\n' "$rh_iter" "$rh_resolved"
        local has_breakdown
        has_breakdown=$(echo "$rh" | jq 'has("breakdown")')
        if [[ "$has_breakdown" == "true" ]]; then
          local pi pe si se ap as_
          pi=$(echo "$rh" | jq -r '.breakdown.proposal_internal // 0')
          pe=$(echo "$rh" | jq -r '.breakdown.proposal_external // 0')
          si=$(echo "$rh" | jq -r '.breakdown.system_internal // 0')
          se=$(echo "$rh" | jq -r '.breakdown.system_external // 0')
          ap=$(echo "$rh" | jq -r '.breakdown.address_reviews_proposal // 0')
          as_=$(echo "$rh" | jq -r '.breakdown.address_reviews_system // 0')
          printf '    proposal: %s internal + %s external\n' "$pi" "$pe"
          printf '    system: %s internal + %s external\n' "$si" "$se"
          printf '    address-reviews: %s proposal + %s system\n' "$ap" "$as_"
        fi
      fi
    fi
  fi

  # Recommended next
  echo ""
  local rec_cmd rec_args rec_reason
  rec_cmd=$(echo "$focus" | jq -r '.recommended_next.command')
  rec_args=$(echo "$focus" | jq -r '.recommended_next.args')
  rec_reason=$(echo "$focus" | jq -r '.recommended_next.reason')
  # Render "Next: <cmd> <args>" only when command is parseable. For prose
  # next_recommended strings (multi-alternative narratives), command/args
  # are null and reason carries the full text — skip the empty "Next:"
  # header and just emit the prose. Caught during W1/W2/W3 batch when the
  # corrected latest-run selection started surfacing prose recommendations.
  if [[ -n "$rec_cmd" && "$rec_cmd" != "null" && "$rec_cmd" != "" ]]; then
    if [[ -n "$rec_args" && "$rec_args" != "null" && "$rec_args" != "" ]]; then
      echo "Next: $rec_cmd $rec_args"
    else
      echo "Next: $rec_cmd"
    fi
    echo "  \"$rec_reason\""
  else
    # Prose recommendation with no parseable leading command — emit a
    # neutral header and the verbatim reason.
    echo "Next:"
    echo "  $rec_reason"
  fi

  # Under --detail (and orbit project), surface the recommendation's source.
  if $DETAIL; then
    local rec_source
    rec_source=$(echo "$focus" | jq -r '.recommended_next.source // empty')
    [[ -n "$rec_source" && "$rec_source" != "null" ]] && echo "  (source: $rec_source)"
  fi

  # Secondary threads
  local sec_count
  sec_count=$(echo "$focus" | jq -r '(.secondary_threads // []) | length')
  if (( sec_count > 0 )); then
    echo ""
    echo "Other active:"
    echo "$focus" | jq -r '.secondary_threads[] | "  \(.name)    \(.summary)"'
  fi

  # Recent archives
  local archived_total
  archived_total=$(enumerate_archived_changes | wc -l | tr -d ' ')
  if (( archived_total > 0 )); then
    echo ""
    echo "Recently archived: $archived_total total (showing up to $LIMIT)"
    echo "$recent_arr" | jq -r '.[] | "  \(.name) · archived \(.archived_at | split("T")[0])"'
  fi
}

if $JSON; then
  emit_json
else
  emit_human
fi
